{% extends "layouts/side-nav-layout.njk" %}
{% from "moj/components/alert/macro.njk" import mojAlert %}
{% from "partials/example.njk" import example %}
{% from "partials/nunjucksMacroOptions.njk" import nunjucksMacroOptions %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% set pageTitle = "Predictor badge" %}
{% set mainClasses = "govuk-body" %}

{% set macroOptions = baseMacroOptions.concat([
  [
    {
      text: "showScore"
    },
    {
      text: "boolean"
    },
    {
      html: 'Override default configuration to always show/hide a score for a predictor (not recommended).'
    }
  ],
  [
    {
      text: "legacyFallback"
    },
    {
      text: "boolean"
    },
    {
      html: 'Default false. Fallback to using the legacy (OGRS3-gen) equivalent of a predictor if the latest assessment is legacy, but a non-legacy predictor was specified. Will have no affect if the predictor specified is legacy or Serious Violent Reoffending Predictor (there is no legacy equivalent version of this predictor).'
    }
  ]
]) %}

{% block sideNavContent %}
  <h1 class="govuk-heading-xl">
    {{ pageTitle }}
    <span>{{ govukTag({text: "BETA"}) }}</span>
  </h1>

  <div id="predictor-badge-wrapper" class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <p>The predictor badge component lets users view the band, score, and type in a badge format. The data is from the latest completed assessment.</p>
      {% set defaultExampleNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}

          {{ predictorBadge({
            data: riskData,
            predictor: "allReoffendingPredictor"
          }) }}
        {% endraw %}
      {% endset %}
      {{ example({data: {riskData: riskData}, exampleNjks: defaultExampleNjks, exampleId: 'default'}) }}
      {{ nunjucksMacroOptions({macroOptions: macroOptions}) }}
      <h2>How to use</h2>
      <p>Refer to the
        <a href="https://dsdmoj.atlassian.net/wiki/spaces/NDSS/pages/4471390821/Risk+badges">Risk badges</a>
        Confluence documentation for usage details.
      </p>
      {{ mojAlert({
        variant: "warning",
        title: "Width constraints",
        showTitleAsHeading: true,
        dismissible: false,
        html: 'Implementing systems should account for the width constraints of the parent container in which the predictor badge is rendered. The standard predictor badge is intended to display as a single line with no text wrapping. If the predictor name and band exceeds the available space and would require wrapping, use the <a href="/expanded-predictor-badge">expanded predictor badge</a> instead.'
      }) }}
      <p>
        Example of when <strong>not</strong> to use this component due to text wrapping:
      </p>
      {% set restrictedWidthExampleWidthNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}
          <div class="badge-restricted-width">
            {{ predictorBadge({
              data: riskData,
              predictor: "indirectImageContactSexualReoffendingPredictor"
            }) }}
          </div>
        {% endraw %}
      {% endset %}
      {{ example({data: {riskData: riskData}, exampleNjks: restrictedWidthExampleWidthNjks, exampleId: 'restricted-width'}) }}

      <h2>Show current (OGRS4-gen) badges for a v2 assessment (no fallback)</h2>
      <p>Display the current (OGRS4-gen) badges for the latest assessment. Note that if the assessment is legacy (v1) or there's no data for this predictor then the badges will not render. If this is not the desired behaviour you may need to add additional validation in your code.</p>
      {% set ogrs4NoFallbackExampleNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}
          <p>Badges for a case with all predictors set.</p>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "allReoffendingPredictor"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "violentReoffendingPredictor"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "seriousViolentReoffendingPredictor"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "directContactSexualReoffendingPredictor"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "indirectImageContactSexualReoffendingPredictor"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "combinedSeriousReoffendingPredictor"
            }) }}
          </div>
          <p>Sexual reoffending badge for the not applicable case:</p>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataNotApplicable,
            predictor: "directContactSexualReoffendingPredictor"
            }) }}
          </div>
        {% endraw %}
      {% endset %}
      {{ example({data: {riskData: riskData, riskDataNotApplicable: riskDataNotApplicable}, exampleNjks: ogrs4NoFallbackExampleNjks, exampleId: 'ogrs4-no-fallback'}) }}

      <h2>Fallback to legacy (OGRS3-gen) badges for a v1 assessment</h2>
      <p>If you need either the current (OGRS4-gen) or the equivalent OGRS3 badge depending on the version of the latest assessment, use the legacyFallback option.</p>
      {% set ogrs4FallbackExampleNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}
          <p>Badges for a case with a version 1 (legacy) latest assessment - we request a current (OGRS4-gen) badge but get the legacy version instead.
            Note that seriousViolentReoffendingPredictor has no fallback so nothing is shown in its place.</p>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "allReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "violentReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "seriousViolentReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "directContactSexualReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "indirectImageContactSexualReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskDataLegacy,
              predictor: "combinedSeriousReoffendingPredictor",
              legacyFallback: true
            }) }}
          </div>
          <p>OGP has been deprecated in the current version so must be explicitly rendered if required.</p>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataLegacy,
            predictor: "ogp"
            }) }}
          </div>
          <p>Badges for a case with a version 2 (current) latest assessment - legacyFallback flag is ignored.</p>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "allReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "violentReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "seriousViolentReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "directContactSexualReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "indirectImageContactSexualReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
            data: riskDataCurrent,
            predictor: "combinedSeriousReoffendingPredictor",
            legacyFallback: true
            }) }}
          </div>
        {% endraw %}
      {% endset %}
      {{ example({data: {riskDataCurrent: riskData, riskDataLegacy: riskDataLegacy}, exampleNjks: ogrs4FallbackExampleNjks, exampleId: 'ogrs4-fallback'}) }}

      <h2>Show legacy (OGRS3-gen) badges for a v1 assessment</h2>
      <p>Display the legacy (OGRS3-gen) badges for the latest assessment. Note that if the assessment is not legacy (v2) or there's no data for this predictor then the badges will not render. If this is not the desired behaviour you may need to add additional validation in your code.</p>
      {% set ogrs3ExampleNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "ogrs3"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "ovp"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "ogp"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "rsr"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "ospdc"
            }) }}
          </div>
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "ospiic"
            }) }}
          </div>
        {% endraw %}
      {% endset %}
      {{ example({data: {riskData: riskDataLegacy}, exampleNjks: ogrs3ExampleNjks, exampleId: 'ogrs3'}) }}

      <h2>Missing bands and scores</h2>
      <p>An unknown state occurs when either the band or score is missing (only if the default/override
        configuration requires the score to be shown).</p>
      {% set unknownExampleNjks %}
        {% raw %}
          {% from "arns/components/predictor-badge/macro.njk" import predictorBadge %}
          <div class="govuk-!-margin-bottom-4">
            {{ predictorBadge({
              data: riskData,
              predictor: "allReoffendingPredictor"
            }) }}
          </div>
        {% endraw %}
      {% endset %}
      {{ example({data: {riskData: riskDataErrorStates}, exampleNjks: unknownExampleNjks, exampleId: 'unknown'}) }}
    </div>
  </div>

{% endblock %}
