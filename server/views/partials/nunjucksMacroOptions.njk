{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% macro nunjucksMacroOptions(params) %}
  {% set optionsHtml %}
    {{ govukTable({
      attributes: {
        id: "options-table"
      },
      firstCellIsHeader: true,
      head: [
        {
          text: "Name"
        },
        {
          text: "Type"
        },
        {
          text: "Description"
        }
      ],
      rows: params.macroOptions
    }) }}
  {% endset %}
  {{ govukDetails({
    summaryText: "Nunjucks macro options",
    attributes: {
      id: "options-details"
    },
    html: optionsHtml
  }) }}
{% endmacro %}
