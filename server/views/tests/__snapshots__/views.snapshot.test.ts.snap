      </a>
    </li>
      
    
  </ul>
  
      <div class="govuk-tabs__panel" id="default-example-rendered">
  
    <div class="arns-badge-base--low"
               data-badge-base="All Reoffending Predictor LOW">
    
            <span class="arns-badge-base__type_and_level" data-test-id="nameAndBand">All Reoffending Predictor <strong>LOW</strong></span>
    
            
              <span class="arns-badge-base__score" data-test-id="score">1.23%</span>
            
    
            
              <span class="arns-badge-base__static_or_dynamic" data-test-id="staticOrDynamic">
                <strong class="govuk-tag govuk-tag--grey arns-badge-base__govuk-tag-sizing">
      Static
    </strong>
    
              </span>
            
          </div>
  
  </div>
    
  
      <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="default-example-nunjucks">
  
    <p>See <a href="#options-details">Nunjucks macro options</a> for more details on how to customise component.</p>
        <pre class="app-example__code"><code>{% from &quot;arns/components/predictor-badge/macro.njk&quot; import predictorBadge %}
    
    {{ predictorBadge({
      data: riskData,
      predictor: &quot;allReoffendingPredictor&quot;
    }) }}</code></pre>
  
  </div>
    
  
