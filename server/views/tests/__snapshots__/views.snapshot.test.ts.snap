      <div class="govuk-width-container">
        
        
        <main class="govuk-main-wrapper govuk-body" id="main-content">
          
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
      <nav class="moj-side-navigation" aria-label="Side navigation" >
      <h4 class="moj-side-navigation__title">Overview</h4>
      <ul class="moj-side-navigation__list">
          <li class="moj-side-navigation__item moj-side-navigation__item--active">
            <a href="/" aria-current="location">Introduction</a>
          </li>
        </ul>
    
      <h4 class="moj-side-navigation__title">Library components</h4>
      <ul class="moj-side-navigation__list">
          <li class="moj-side-navigation__item">
            <a href="/predictor-badge">Predictor badge</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/rosh-badge">ROSH badge</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/expanded-predictor-badge">Expanded predictor badge</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/predictor-scale">Predictor scale</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/predictor-timeline">Predictor timeline</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/detailed-risk-predictor-scores">Detailed risk predictor scores</a>
          </li>
        </ul>
    
      <h4 class="moj-side-navigation__title">Snippet components</h4>
      <ul class="moj-side-navigation__list">
          <li class="moj-side-navigation__item">
            <a href="/mappa-widget">MAPPA widget</a>
          </li>
        
          <li class="moj-side-navigation__item">
            <a href="/risk-flag-widget">Risk flag widget</a>
