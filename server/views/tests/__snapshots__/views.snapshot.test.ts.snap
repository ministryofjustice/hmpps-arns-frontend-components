               data-badge-base="Violent Reoffending Predictor LOW">
    
            <span class="arns-badge-base__type_and_level" data-test-id="nameAndBand">Violent Reoffending Predictor <strong>LOW</strong></span>
    
            
              <span class="arns-badge-base__score" data-test-id="score">1.23%</span>
            
    
            
              <span class="arns-badge-base__static_or_dynamic" data-test-id="staticOrDynamic">
                <strong class="govuk-tag govuk-tag--grey arns-badge-base__govuk-tag-sizing">
      Static
    </strong>
    
              </span>
            
          </div>
        
      
        
      
        
      
        
      
        
      
    
    
              </div>
              <div class="govuk-!-margin-bottom-4">
                
    
    
    
      
    
      
        
      
    
      
        
      
        
      
        
      
        
      
        
    
          
          
    
        
      
    
      
    
