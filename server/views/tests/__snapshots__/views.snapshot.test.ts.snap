          <div class="arns-predictor-scale govuk-body" data-predictor-scale="All Reoffending Predictor">
            
              <div class="arns-predictor-scale-header-wrapper">
                <div>
                  <h4 class="govuk-heading-xs predictor-scale-header" data-test-id="name">All Reoffending Predictor</h4>
                  
                  <p class="govuk-hint" data-test-id="LastUpdatedDate">Last updated: 01 January 2025</p>
                  
                </div>
                
                  <div data-test-id="staticOrDynamic"><strong class="govuk-tag govuk-tag--grey">
      Static
    </strong>
    </div>
                
