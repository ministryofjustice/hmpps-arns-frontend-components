      <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="customHeaderDate-example-nunjucks">
  
    <p>See <a href="#options-details">Nunjucks macro options</a> for more details on how to customise component.</p>
        <pre class="app-example__code"><code>{% from &quot;arns/components/predictor-scale/macro.njk&quot; import predictorScale %}
    
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorScale({
      data: riskData,
      predictor: &quot;allReoffendingPredictor&quot;,
      headingLevel: 4,
      headingClass: &quot;xs&quot;
      }) }}
    &lt;/div&gt;</code></pre>
  
  </div>
    
  
      <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="customHeaderDate-example-data">
  
