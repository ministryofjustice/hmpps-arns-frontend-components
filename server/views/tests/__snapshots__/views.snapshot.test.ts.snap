  <h1 class="govuk-heading-xl">
    Risk flag widget
  </h1>

  <div id="risk-flag-widget-wrapper" class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      

<div
  role="region"
  class="moj-alert moj-alert--warning moj-alert--with-heading"
  aria-label="warning: Snippet component"
  data-module="moj-alert">
  <div>
    <svg class="moj-alert__icon" role="presentation" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" height="30" width="30"><path fill-rule="evenodd" clip-rule="evenodd" d="M15 2.44922L28.75 26.1992H1.25L15 2.44922ZM13.5107 9.49579H16.4697L16.2431 17.7678H13.7461L13.5107 9.49579ZM13.1299 21.82C13.1299 21.5661 13.1787 21.3285 13.2764 21.1071C13.374 20.8793 13.5075 20.6807 13.6768 20.5114C13.8525 20.3421 14.0544 20.2087 14.2822 20.111C14.5101 20.0134 14.7542 19.9645 15.0146 19.9645C15.2686 19.9645 15.5062 20.0134 15.7275 20.111C15.9554 20.2087 16.154 20.3421 16.3232 20.5114C16.4925 20.6807 16.626 20.8793 16.7236 21.1071C16.8213 21.3285 16.8701 21.5661 16.8701 21.82C16.8701 22.0804 16.8213 22.3246 16.7236 22.5524C16.626 22.7803 16.4925 22.9789 16.3232 23.1481C16.154 23.3174 15.9554 23.4509 15.7275 23.5485C15.5062 23.6462 15.2686 23.695 15.0146 23.695C14.7542 23.695 14.5101 23.6462 14.2822 23.5485C14.0544 23.4509 13.8525 23.3174 13.6768 23.1481C13.5075 22.9789 13.374 22.7803 13.2764 22.5524C13.1787 22.3246 13.1299 22.0804 13.1299 21.82Z" fill="currentColor"/>
    </svg>
  </div>
  <div class="moj-alert__content">
      <h2 class="moj-alert__heading">Snippet component
      </h2>This component is currently provided as a snippet and is not yet included in the library. It will be moved into the library in a future release.</div>

  <div class="moj-alert__action">
    <button class="moj-alert__dismiss" hidden>Dismiss</button>
  </div>
</div>

      <h2>How to use</h2>
      <p>
        Refer to the <a
          href="https://dsdmoj.atlassian.net/wiki/spaces/NDSS/pages/4474110284/Delius+risk+flags+registers">Delius risk flags (registers)</a>
        Confluence documentation for usage details.
      </p>
      <h3>Code</h3>
      <p>
        The <a
          href="https://github.com/ministryofjustice/hmpps-arns-frontend-components/tree/main/server/views/partials/risk-flag-widget">Risk flag
          widget Nunjucks macro</a> is available on GitHub.
        <br>
        The <a
          href="https://github.com/ministryofjustice/hmpps-arns-frontend-components/blob/main/assets/scss/partials/risk/_risk-flag-widget.scss">Risk flag
          widget SCSS</a> is available on GitHub.
      </p>
      <h3>Input data format</h3>
      <p>
        The risk flag widget includes the following fields, which must follow the specified format:
      </p>
      <ul>
        <li>flags (List of objects)</li>
          <ul>
            <li>description (string)</li>
          </ul>
        </li>
      </ul>
      <h4>E.g.</h4>
      <pre>
        <code>
flags: [
  { description: 'Hate Crime' },
  { description: 'Assault' }
]
        </code>
      </pre>
    </div>
  </div>
  <h2>Examples</h2>
  <div id="risk-flag-widget-wrapper" class="govuk-grid-row">
    <div id="risk-flag-widget" class="govuk-grid-column-one-third">
      <aside class="risk-flag-widget" aria-label="Delius risk flags">
    <h3 class="govuk-heading-m">Delius risk flags (registers)</h3>
    <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
    
        
            <ul class="govuk-list" aria-label="Risk flags">
            
                <li>Hate Crime</li>
            
                <li>Assault</li>
            
            </ul>
        
    
</aside>

    </div>
    <div id="risk-flag-widget-no-matching-data" class="govuk-grid-column-one-third">
      <aside class="risk-flag-widget" aria-label="Delius risk flags">
    <h3 class="govuk-heading-m">Delius risk flags (registers)</h3>
    <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
    
        
            <p>No risks</p>
        
    
</aside>

    </div>
    <div id="risk-flag-widget-null-data" class="govuk-grid-column-one-third">
      <aside class="risk-flag-widget" aria-label="Delius risk flags">
    <h3 class="govuk-heading-m">Delius risk flags (registers)</h3>
