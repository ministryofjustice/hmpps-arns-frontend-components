              &quot;band&quot;: &quot;HIGH&quot;,
              &quot;staticOrDynamic&quot;: &quot;Static&quot;,
              &quot;score&quot;: 1.23,
              &quot;completedDate&quot;: &quot;01 January 2025&quot;
            }
          },
          {
            &quot;outputVersion&quot;: &quot;1&quot;,
            &quot;completedDateTime&quot;: &quot;02 January 2024 at 18:23&quot;,
            &quot;ogrs3&quot;: {
              &quot;name&quot;: &quot;OGRS&quot;,
              &quot;band&quot;: &quot;LOW&quot;,
              &quot;staticOrDynamic&quot;: null,
              &quot;score&quot;: 5,
              &quot;completedDate&quot;: &quot;02 January 2024&quot;
            },
            &quot;ovp&quot;: {
              &quot;name&quot;: &quot;OVP&quot;,
              &quot;band&quot;: &quot;LOW&quot;,
              &quot;staticOrDynamic&quot;: null,
              &quot;score&quot;: 7,
              &quot;completedDate&quot;: &quot;02 January 2024&quot;
            },
            &quot;ogp&quot;: {
