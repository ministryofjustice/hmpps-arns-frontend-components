  </ul>
  
      <div class="govuk-tabs__panel" id="dynamicWidth-example-rendered">
  
    <div class="govuk-!-margin-bottom-4">
                
    
    
    
      
    
      
        
      
    
      
        
      
        
      
        
    
          
    
          
          
            
          
    
          
          
    
          
            
          
    
          
            
          
    
          <div class="arns-expanded-predictor-badge--low arns-expanded-predictor-badge__dynamic"
               data-expanded-predictor-badge="All Reoffending Predictor LOW">
    
            <span
              class="arns-predictor-badge__type" data-test-id="name">All Reoffending Predictor</span>
    
            <div class="arns-predictor-badge__stats" data-test-id="badgeStats">
              <span class="arns-predictor-badge__level" data-test-id="band">LOW</span>
    
              
                <span class="arns-predictor-badge__score" data-test-id="score">1.23%</span>
              
    
              
                <span  data-test-id="staticOrDynamic">
                  <strong class="govuk-tag govuk-tag--grey arns-predictor-badge__static_or_dynamic">
      Static
    </strong>
    
                </span>
              
    
            </div>
            
              <span class="arns-predictor-badge__last_updated" data-test-id="completedDate">Last updated: 01 January 2025</span>
            
    
          </div>
        
      
        
      
        
      
        
      
        
      
        
      
    
    
              </div>
              <div class="govuk-!-margin-bottom-4">
                
    
    
    
      
    
      
        
      
    
      
        
      
        
      
        
      
        
      
        
      
        
      
        
    
          
    
          
          
            
          
    
          
          
    
          
            
          
    
          
            
          
    
          <div class="arns-expanded-predictor-badge--high arns-expanded-predictor-badge__dynamic"
               data-expanded-predictor-badge="Images and Indirect Contact – Sexual Reoffending Predictor HIGH">
    
            <span
              class="arns-predictor-badge__type" data-test-id="name">Images and Indirect Contact – Sexual Reoffending Predictor</span>
    
            <div class="arns-predictor-badge__stats" data-test-id="badgeStats">
              <span class="arns-predictor-badge__level" data-test-id="band">HIGH</span>
    
              
    
              
    
            </div>
            
