  <div class="moj-alert__content">
      <h2 class="moj-alert__heading">JavaScript import required
      </h2><p>
          This component requires a JavaScript import for full functionality. See the
          <a href="/#js-import">home page</a> for details.
        </p></div>

  <div class="moj-alert__action">
    <button class="moj-alert__dismiss" hidden>Dismiss</button>
  </div>
</div>

      <p>The predictor timeline component lets users view the history of a subjects assessments.</p>
      

  

  

  

  

  <div class="govuk-tabs"
    
        
        
      
        
      
    
   id="options-default-example-tabs" data-module="govuk-tabs">
  <h2 class="govuk-tabs__title">
    Contents
  </h2>

  <ul class="govuk-tabs__list">
    
          <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
      <a class="govuk-tabs__tab" href="#default-example-rendered">
        Rendered
      </a>
    </li>
      
    
          <li class="govuk-tabs__list-item">
      <a class="govuk-tabs__tab" href="#default-example-nunjucks">
        Nunjucks
      </a>
    </li>
      
    
