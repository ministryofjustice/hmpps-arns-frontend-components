      <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="ogrs4-fallback-example-nunjucks">
  
    <p>See <a href="#options-details">Nunjucks macro options</a> for more details on how to customise component.</p>
        <pre class="app-example__code"><code>{% from &quot;arns/components/predictor-badge/macro.njk&quot; import predictorBadge %}
    &lt;p&gt;Badges for a case with a version 1 (legacy) latest assessment - we request a current (OGRS4-gen) badge but get the legacy version instead.
      Note that seriousViolentReoffendingPredictor has no fallback so nothing is shown in its place.&lt;/p&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;allReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;violentReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;seriousViolentReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;directContactSexualReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;indirectImageContactSexualReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
        data: riskDataLegacy,
        predictor: &quot;combinedSeriousReoffendingPredictor&quot;,
        legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;p&gt;OGP has been deprecated in the current version so must be explicitly rendered if required.&lt;/p&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataLegacy,
      predictor: &quot;ogp&quot;
      }) }}
    &lt;/div&gt;
    &lt;p&gt;Badges for a case with a version 2 (current) latest assessment - legacyFallback flag is ignored.&lt;/p&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;allReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;violentReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;seriousViolentReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;directContactSexualReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;indirectImageContactSexualReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;
    &lt;div class=&quot;govuk-!-margin-bottom-4&quot;&gt;
      {{ predictorBadge({
      data: riskDataCurrent,
      predictor: &quot;combinedSeriousReoffendingPredictor&quot;,
      legacyFallback: true
      }) }}
    &lt;/div&gt;</code></pre>
  
  </div>
    
  
