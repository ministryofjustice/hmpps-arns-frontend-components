      <td class="govuk-table__cell">1</td>
      
    
    </tr>
  

  
    <tr class="govuk-table__row">
    
      
      
      <th scope="row" class="govuk-table__header">High</th>
      
    
      
      
      <td class="govuk-table__cell">2 or more</td>
      
    
    </tr>
  

  </tbody>
</table>

              </div>
            </div>
          
  </section>
</details>

